# ── Telegram Alert Config ─────────────────
# 1. Message @BotFather on Telegram, send /newbot, pick a name
# 2. You'll receive a token, paste it below
# 3. Send any message to your new bot
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates to get your chat_id
# 5. Paste chat_id below

TELEGRAM_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=123456789
